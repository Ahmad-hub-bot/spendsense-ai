name: SpendSense Daily Summary

# Runs automatically every evening, independent of the Streamlit app.
# Cron is in UTC — 18:30 UTC = 10:30 PM Gulf Standard Time (Dubai, UTC+4).
# Adjust the cron expression below if you want a different local time.
on:
  schedule:
    - cron: "30 18 * * *"
  workflow_dispatch: {}   # lets you trigger it manually from the Actions tab too

jobs:
  send-daily-summary:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          pip install pandas gspread google-auth google-genai requests scikit-learn

      - name: Run daily summary script
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}
          GSHEET_NAME: ${{ secrets.GSHEET_NAME }}
          GCP_SERVICE_ACCOUNT_JSON: ${{ secrets.GCP_SERVICE_ACCOUNT_JSON }}
        run: python daily_summary.py
